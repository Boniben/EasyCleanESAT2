{% from '_macros/action_buttons.html.twig' import action_buttons %}
{% extends 'base.html.twig' %}

{% block title %}Contenants{% endblock %}

{% block body %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1>Contenants</h1>
        <a href="{{ path('app_contenant_new') }}" class="btn btn-success" style="font-size: 16px; padding: 10px 20px;">+ Creer</a>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Volume eau</th>
                <th>Picto</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for contenant in contenants %}
            <tr>
                <td>{{ contenant.id }}</td>
                <td>{{ contenant.nom }}</td>
                <td>{{ contenant.volumeEau }}</td>
                <td>
                    <img src="{{ asset('PictoContenantPNG/' ~ contenant.id ~ '.png') }}" alt="Pictogramme {{ contenant.nom }}" style="max-height: 40px;">
                </td>
                <td>

                    {{ action_buttons('app_contenant_show', 'app_contenant_edit', contenant.id) }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun enregistrement trouve</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
