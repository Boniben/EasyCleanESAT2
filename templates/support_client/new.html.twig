{% extends 'base.html.twig' %}

{% block title %}Ajouter des supports{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Ajouter des supports</h1>
            {% if zone %}
                <p class="text-muted text-sm">{{ zone.nom }} — {{ zone.sitesClient.nom }} — {{ zone.sitesClient.client.nom }}</p>
            {% endif %}
        </div>
    </div>

    {# Supports déjà assignés #}
    {% if zone and zone.supportsClient|length > 0 %}
        <div class="card" style="margin-bottom: 1.25rem;">
            <h3 style="margin-bottom: 0.25rem;">Supports déjà assignés</h3>
            <p class="text-muted text-sm" style="margin-bottom: 0.75rem;">Cliquer sur un support pour le retirer</p>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
                {% for support in zone.supportsClient %}
                    <form method="POST" action="{{ path('app_support_client_delete', {'id': support.id}) }}" style="margin:0;" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ support.id) }}">
                        <button type="submit" title="Retirer {{ support.typeSupport.nom }}" style="
                            background: none; border: 2px solid var(--color-border); border-radius: var(--radius-lg);
                            padding: 0.6rem 0.5rem; cursor: pointer; display: flex; flex-direction: column;
                            align-items: center; gap: 0.3rem; transition: all 0.2s ease; min-width: 70px;
                        "
                        onmouseenter="this.style.borderColor='var(--color-danger)';this.style.background='#fdf0f0';"
                        onmouseleave="this.style.borderColor='var(--color-border)';this.style.background='none';">
                            {% if support.typeSupport.picto %}
                                <img src="{{ asset('PictoTypeSupportPNG/' ~ support.typeSupport.picto) }}"
                                     alt="{{ support.typeSupport.nom }}"
                                     style="width: 52px; height: 52px; object-fit: contain; pointer-events: none;">
                            {% else %}
                                <div style="width:52px;height:52px;background:var(--color-primary-light);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:1.5rem;pointer-events:none;">🪣</div>
                            {% endif %}
                            <span style="font-size:0.72rem;color:var(--color-text-secondary);text-align:center;max-width:70px;pointer-events:none;">{{ support.typeSupport.nom }}</span>
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Supports disponibles à ajouter #}
    <form method="POST" id="support-form" data-turbo="false">
        <input type="hidden" name="zone_id" value="{{ zone ? zone.id : '' }}">

        {% if availableTypeSupports|length > 0 %}
            <h3 style="margin-bottom: 1rem;">Cliquer pour ajouter</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem;">
                {% for ts in availableTypeSupports %}
                    <div class="support-tile"
                         data-id="{{ ts.id }}"
                         data-nom="{{ ts.nom }}"
                         style="
                            display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
                            padding: 0.75rem 0.5rem;
                            border: 2px solid var(--color-border);
                            border-radius: var(--radius-lg);
                            background: white;
                            cursor: pointer;
                            transition: all 0.2s ease;
                            text-align: center;
                         ">
                        {% if ts.picto %}
                            <img src="{{ asset('PictoTypeSupportPNG/' ~ ts.picto) }}"
                                 alt="{{ ts.nom }}"
                                 style="width: 52px; height: 52px; object-fit: contain; pointer-events: none;">
                        {% else %}
                            <div style="width:52px;height:52px;background:var(--color-primary-light);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:1.5rem;pointer-events:none;">🪣</div>
                        {% endif %}
                        <span style="font-size: 0.78rem; font-weight: 600; color: var(--color-primary-hover); pointer-events: none;">{{ ts.nom }}</span>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted text-sm" style="margin-bottom: 1.5rem;">Tous les types de support sont déjà assignés à cette zone.</p>
        {% endif %}

        <div class="btn-group">
            <button class="btn btn-primary" type="submit" id="btn-save" disabled>Sauvegarder</button>
            <a href="{{ zone ? path('app_zones_client_show', {'id': zone.id}) : path('app_client_index') }}" class="btn btn-secondary">Annuler</a>
        </div>
    </form>

    <script>
    const form = document.getElementById('support-form');
    const btnSave = document.getElementById('btn-save');
    const selected = {};

    document.querySelectorAll('.support-tile').forEach(tile => {
        tile.addEventListener('click', () => {
            const id = tile.dataset.id;
            if (selected[id]) {
                delete selected[id];
                tile.style.borderColor = 'var(--color-border)';
                tile.style.background = 'white';
                tile.style.transform = '';
                form.querySelector('input[name="type_support_ids[]"][value="' + id + '"]')?.remove();
            } else {
                selected[id] = true;
                tile.style.borderColor = 'var(--color-success)';
                tile.style.background = '#eaf5ef';
                tile.style.transform = 'scale(1.05)';
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'type_support_ids[]';
                hidden.value = id;
                form.appendChild(hidden);
            }
            btnSave.disabled = Object.keys(selected).length === 0;
        });

        tile.addEventListener('mouseenter', () => {
            if (!selected[tile.dataset.id]) tile.style.borderColor = 'var(--color-primary)';
        });
        tile.addEventListener('mouseleave', () => {
            if (!selected[tile.dataset.id]) tile.style.borderColor = 'var(--color-border)';
        });
    });
    </script>
{% endblock %}
