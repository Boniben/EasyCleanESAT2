{% extends 'base.html.twig' %}

{% block title %}{{ client.nom }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
    .client-hero {
        display: flex;
        align-items: center;
        background: white;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: 0.9rem 1.25rem;
        margin-bottom: 1rem;
        position: relative;
    }
    .client-hero__logo {
        width: 140px;
        height: 140px;
        object-fit: contain;
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
        background: var(--color-bg);
        padding: 0.5rem;
        flex-shrink: 0;
    }
    .client-hero__logo-fallback {
        width: 140px;
        height: 140px;
        border-radius: var(--radius-lg);
        background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary-soft));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        flex-shrink: 0;
    }
    .client-hero__info {
        flex: 1;
        text-align: center;
    }
    .client-hero__info h1 {
        font-size: 2rem;
        margin-bottom: 0;
        color: var(--color-primary-hover);
    }

    .site-block {
        background: white;
        border: 2px solid var(--color-primary-soft);
        border-radius: var(--radius-xl);
        box-shadow: 0 2px 12px rgba(61,90,128,0.09);
        margin-bottom: 1.5rem;
        overflow: hidden;
    }
    .site-block__header {
        background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
        padding: 0.85rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .site-block__header h2 {
        color: #fff;
        margin: 0;
        font-size: 1.15rem;
        text-align: center;
        flex: 1;
    }
    .site-block__header .btn-group {
        flex-shrink: 0;
    }
    .site-block__header .btn {
        color: rgba(255,255,255,0.85);
        border-color: rgba(255,255,255,0.3);
        background: rgba(255,255,255,0.12);
        font-size: 0.78rem;
    }
    .site-block__header .btn:hover {
        background: rgba(255,255,255,0.25);
        color: #fff;
    }

    .site-table {
        width: 100%;
        border-collapse: collapse;
    }
    .site-table th {
        background: var(--color-primary-light);
        color: var(--color-primary-hover);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.6rem 1.25rem;
        border-bottom: 2px solid var(--color-primary-soft);
    }
    .site-table td {
        padding: 0.6rem 1.25rem;
        border-bottom: 1px solid var(--color-border);
        font-size: 0.88rem;
        vertical-align: middle;
    }
    .site-table tr:last-child td {
        border-bottom: none;
    }
    .site-table tr:hover td {
        background: rgba(61,90,128,0.04);
    }
    .site-table .zone-name {
        color: var(--color-text);
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.6rem;
        border-radius: var(--radius-md);
        transition: all 0.18s ease;
        text-decoration: none;
    }
    .site-table .zone-name:hover {
        background: #e8f5ee;
        color: var(--color-success);
        transform: translateX(3px);
    }
    .site-table .contrat-link {
        color: var(--color-primary);
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.6rem;
        border-radius: var(--radius-md);
        transition: all 0.18s ease;
        text-decoration: none;
    }
    .site-table .contrat-link:hover {
        background: var(--color-primary-light);
        color: var(--color-primary-hover);
        transform: translateX(3px);
    }
    .tag-empty {
        color: var(--color-text-secondary);
        font-style: italic;
        font-size: 0.82rem;
    }
    </style>
{% endblock %}

{% block body %}

    {# ---- En-tête client ---- #}
    <div class="client-hero">
        {# Espace gauche pour équilibrer le picto à droite #}
        <div style="width:140px; flex-shrink:0;"></div>

        <div class="client-hero__info">
            <h1>{{ client.nom }}</h1>
        </div>

        {% if client.picto %}
            <img src="{{ asset('PictoClientsPNG/' ~ client.picto) }}"
                 alt="{{ client.nom }}"
                 class="client-hero__logo"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            <div class="client-hero__logo-fallback" style="display:none;">🏢</div>
        {% else %}
            <div class="client-hero__logo-fallback">🏢</div>
        {% endif %}
    </div>

    {% if app.user and is_granted('ROLE_ADMIN') %}
        <div class="btn-group" style="margin-bottom: 1.25rem;">
            <a href="{{ path('app_sites_client_new', {'client_id': client.id}) }}" class="btn btn-primary btn-sm">+ Ajouter un site</a>
            <a href="{{ path('app_client_edit', {'id': client.id}) }}" class="btn btn-secondary btn-sm">Modifier le client</a>
        </div>
    {% endif %}

    {# ---- Sites ---- #}
    {% for site in client.sitesClients %}
        <div class="site-block">
            <div class="site-block__header">
                <h2>{{ site.nom }}</h2>
                {% if app.user and is_granted('ROLE_ADMIN') %}
                    <div class="btn-group">
                        <a href="{{ path('app_zones_client_new', {'site_id': site.id}) }}" class="btn btn-sm">+ Zone</a>
                        <a href="{{ path('app_contrat_new', {'site_id': site.id}) }}" class="btn btn-sm">+ Contrat</a>
                    </div>
                {% endif %}
            </div>

            {# Tableau site / contrat / zone #}
            {% set contrats = site.contrats %}
            {% set zones = site.zonesClients %}

            {% if contrats|length > 0 or zones|length > 0 %}
                <table class="site-table">
                    <tbody>
                        <tr>
                            <th style="background: var(--color-primary-light); color: var(--color-primary-hover); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 1.25rem; border-bottom: 1px solid var(--color-primary-soft);">Contrats</th>
                            <td style="padding: 0.6rem 1.25rem; border-bottom: 1px solid var(--color-border);">
                                <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
                                    {% if contrats|length > 0 %}
                                        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.4rem 1.2rem;">
                                            {% for contrat in contrats %}
                                                <li>
                                                    <a href="{{ path('app_contrat_show', {'id': contrat.id}) }}" class="contrat-link">📄 {{ contrat.numero }}</a>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <span class="tag-empty">Aucun contrat</span>
                                    {% endif %}
                                    {% if app.user and is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('app_contrat_new', {'site_id': site.id}) }}" class="btn btn-danger btn-sm" style="flex-shrink: 0;">+ Contrat</a>
                                    {% else %}
                                        <a href="{{ path('app_login') }}" class="btn btn-danger btn-sm" style="flex-shrink: 0;">+ Contrat</a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th style="background: var(--color-primary-light); color: var(--color-primary-hover); font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.5rem 1.25rem;">Zones</th>
                            <td style="padding: 0.6rem 1.25rem;">
                                <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
                                {% if zones|length > 0 %}
                                    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.4rem 1.2rem;">
                                        {% for zone in zones %}
                                            <li><a href="{{ path('app_zones_client_show', {'id': zone.id}) }}" class="zone-name" style="text-decoration: none;">📍 {{ zone.nom }}</a></li>
                                        {% endfor %}
                                    </ul>
                                {% else %}
                                    <span class="tag-empty">Aucune zone</span>
                                {% endif %}
                                <a href="{{ path('app_zones_client_new', {'site_id': site.id}) }}" class="btn btn-success btn-sm" style="flex-shrink: 0;">+ Zone</a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            {% else %}
                <p class="tag-empty" style="padding: 1rem 1.25rem;">Aucun contrat ni zone pour ce site.</p>
            {% endif %}
        </div>
    {% else %}
        <div class="site-block">
            <p class="tag-empty" style="padding: 1rem 1.25rem;">Aucun site pour ce client.</p>
        </div>
    {% endfor %}

    <div class="btn-group mt-3">
        <a href="{{ path('app_client_index') }}" class="btn btn-secondary">← Retour à la liste</a>
        {% if app.user and is_granted('ROLE_ADMIN') %}
            {{ include('client/_delete_form.html.twig') }}
        {% endif %}
    </div>

{% endblock %}
