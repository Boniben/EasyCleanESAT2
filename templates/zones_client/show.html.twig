{% extends 'base.html.twig' %}

{% block title %}Zone —
	{{ zones_client.nom }}
{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<h1>{{ zones_client.nom }}</h1>
			<p class="text-muted text-sm">{{ zones_client.sitesClient.client.nom }}
				—
				{{ zones_client.sitesClient.nom }}</p>
		</div>
		<div class="btn-group">
			<a href="{{ path('app_support_client_new', {'zone_id': zones_client.id}) }}" class="btn btn-success">+ Ajouter un support</a>
			<a href="{{ path('app_zones_client_edit', {'id': zones_client.id}) }}" class="btn btn-secondary">Modifier le nom de la zone</a>
		</div>
	</div>

	<div class="card">
		<h3>Supports</h3>
		{% if zones_client.supportsClient|length > 0 %}
			<div style="display: flex; flex-wrap: wrap; gap: 1rem; padding: 0.5rem 0;">
				{% for support in zones_client.supportsClient %}
					<div style="display: flex; flex-direction: column; align-items: center; gap: 0.4rem;">
						{% if support.typeSupport.picto %}
							<img src="{{ asset('PictoTypeSupportPNG/' ~ support.typeSupport.picto) }}"
								 alt="{{ support.typeSupport.nom }}"
								 title="{{ support.typeSupport.nom }}"
								 style="width: 56px; height: 56px; object-fit: contain;">
						{% else %}
							<div style="width: 56px; height: 56px; background: var(--color-primary-light); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🪣</div>
						{% endif %}
					</div>
				{% endfor %}
			</div>
		{% else %}
			<p class="text-muted text-sm" style="margin-top:0.75rem;">Aucun support pour cette zone</p>
		{% endif %}
	</div>
	<div class="btn-group mt-3">
		<a href="{{ path('app_client_show', {'id': zones_client.sitesClient.client.id}) }}" class="btn btn-secondary">← Retour au client</a>
		{% if app.user and is_granted('ROLE_ADMIN') %}
			{{ include('zones_client/_delete_form.html.twig') }}
		{% else %}
			<a href="{{ path('app_login') }}" class="btn btn-danger">Supprimer</a>
		{% endif %}
	</div>
{% endblock %}
