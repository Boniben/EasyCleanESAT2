{% extends 'base.html.twig' %}

{% block title %}Zone —
	{{ zones_client.nom }}
{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<h1>{{ zones_client.nom }}</h1>
			<p class="text-muted text-sm">{{ zones_client.sitesClient.client.nom }}
				—
				{{ zones_client.sitesClient.nom }}</p>
		</div>
		<div class="btn-group">
			<a href="{{ path('app_intervention_new', {'zones_client_id': zones_client.id}) }}" class="btn btn-success">+ Nouvelle intervention</a>
			<a href="{{ path('app_support_client_new', {'zone_id': zones_client.id}) }}" class="btn btn-primary">Ajouter un support</a>
			<a href="{{ path('app_zones_client_edit', {'id': zones_client.id}) }}" class="btn btn-secondary">Modifier</a>
		</div>
	</div>

	<div class="card">
		<ul class="info-list">
			<li>
				<span class="info-label">Type de zone :</span>
				<span>
					{% if zones_client.typeZone %}
						{% if zones_client.typeZone.picto %}
							<img src="{{ asset('PictoTypeZonePNG/' ~ zones_client.typeZone.picto) }}" alt="{{ zones_client.typeZone.nom }}" style="max-height:28px; vertical-align:middle; margin-right:6px;">
						{% endif %}
						{{ zones_client.typeZone.nom }}
					{% else %}
						Sans type
					{% endif %}
				</span>
			</li>
			<li>
				<span class="info-label">Site :</span>
				<span>{{ zones_client.sitesClient.nom }}</span>
			</li>
			<li>
				<span class="info-label">Client :</span>
				<a href="{{ path('app_client_show', {'id': zones_client.sitesClient.client.id}) }}">{{ zones_client.sitesClient.client.nom }}</a>
			</li>
		</ul>
	</div>

	<div class="card" style="margin-top:0.75rem;">
		<div class="card-header">
			<h2>Supports</h2>
			<a href="{{ path('app_support_client_new', {'zone_id': zones_client.id}) }}" class="btn btn-sm btn-primary">+ Ajouter</a>
		</div>

		{% if zones_client.supportsClient|length > 0 %}
			<div class="table-wrapper" style="margin-top:0.75rem;">
				<table>
					<thead>
						<tr>
							<th>Picto</th>
							<th>Nom du support</th>
							{% if app.user and is_granted('ROLE_ADMIN') %}
								<th>Action</th>
							{% endif %}
						</tr>
					</thead>
					<tbody>
						{% for support in zones_client.supportsClient %}
							<tr>
								<td style="width:60px; text-align:center;">
									{% if support.typeSupport.picto %}
										<img src="{{ asset('PictoTypeSupportPNG/' ~ support.typeSupport.picto) }}" alt="{{ support.typeSupport.nom }}" style="max-height:28px;">
									{% else %}
										—
									{% endif %}
								</td>
								<td>{{ support.typeSupport.nom }}</td>
								{% if app.user and is_granted('ROLE_ADMIN') %}
									<td>
										<form method="post" action="{{ path('app_support_client_delete', {'id': support.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce support ?')">
											<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ support.id) }}">
											<button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
										</form>
									</td>
								{% endif %}
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		{% else %}
			<p class="text-muted text-sm" style="margin-top:0.75rem;">Aucun support pour cette zone</p>
		{% endif %}
	</div>

	{% if app.user and is_granted('ROLE_ADMIN') %}
		{{ include('zones_client/_delete_form.html.twig') }}
	{% endif %}

	<div class="btn-group mt-3">
		<a href="{{ path('app_client_show', {'id': zones_client.sitesClient.client.id}) }}" class="btn btn-secondary">← Retour au client</a>
	</div>
{% endblock %}
