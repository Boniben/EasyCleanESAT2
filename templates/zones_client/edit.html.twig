{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ zones_client.nom }}{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Modifier la zone</h1>
            <p class="text-muted text-sm">{{ zones_client.sitesClient.client.nom }} — {{ zones_client.sitesClient.nom }}</p>
        </div>
    </div>

    <div class="form-card">
        {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.nom, 'Nom de la zone') }}
                {{ form_widget(form.nom) }}
            </div>

            <div class="form-group">
                {{ form_label(form.typeZone, 'Type de zone') }}
                {{ form_widget(form.typeZone) }}
            </div>

            <div class="form-actions">
                <button class="btn btn-primary" type="submit">Enregistrer</button>
                <a href="{{ path('app_zones_client_show', {'id': zones_client.id}) }}" class="btn btn-secondary">Annuler</a>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}
