}
/* Carte picto action */
.action-picto-card {
    border: solid 1px #000;
    background: #fff;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
}
.action-picto-top {
    border-bottom: solid 1px #000;
    padding: 6px 8px;
    text-align: center;
}
.action-picto-tache-nom {
    font-weight: bold;
    font-size: 0.78rem;
    margin-bottom: 4px;
}
.action-picto-tache-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    display: block;
    margin: 0 auto;
}
.action-picto-bottom {
    display: flex;
    padding: 4px;
    align-items: center;
}
.action-picto-grid {
    display: grid;
    grid-template-columns: repeat(2, 32px);
    gap: 2px;
}
.action-picto-nec-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border: 1px solid #ccc;
}
/* Filtres nécessaires */
.action-filter-chips {
    margin-bottom: 0.8rem;
}
.filter-selects-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: flex-start;
}
.filter-select-group {
    display: flex;
    flex-direction: column;
    gap: 3px;
}
.filter-select-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}
.filter-list {
    border: 1px solid #adb5bd;
    border-radius: 4px;
    min-width: 130px;
