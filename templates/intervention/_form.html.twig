    max-height: 120px;
    overflow-y: auto;
    background: #fff;
}
.filter-list-item {
    padding: 4px 8px;
    font-size: 0.82rem;
    cursor: pointer;
    user-select: none;
    border-bottom: 1px solid #f0f0f0;
    transition: background 0.1s;
}
.filter-list-item:last-child {
    border-bottom: none;
}
.filter-list-item:hover {
    background: #dce4ed;
    color: #3d5a80;
}
.filter-list-item.active {
    background: #3d5a80;
    color: #fff;
}
.filter-list-item.active:hover {
    background: #2d4a70;
}

/* ── Champs vides : teinte pastel orange ──────────────────────────────────── */
input:placeholder-shown:not([type="hidden"]):not([type="submit"]),
textarea:placeholder-shown {
    background-color: #fff4ec !important;
    border-color: #f0a07a !important;
}
input[type="time"].field-empty,
input[type="number"].field-empty,
select.field-empty {
    background-color: #fff4ec !important;
    border-color: #f0a07a !important;
}

/* ── Points de vigilance ───────────────────────────────────────────────────── */
.vigil-select-row {
    display: flex;
    gap: 10px;
    align-items: center;
}
.vigil-dropdown {
    flex: 1;
    padding: 9px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 0.95rem;
    background: #fff;
    cursor: pointer;
}
.vigil-dropdown:focus {
    outline: none;
    border-color: #3d5a80;
}
.vigil-add-btn {
    flex-shrink: 0;
    padding: 9px 18px;
}
.vigil-counter {
    font-size: 0.82rem;
    color: #555;
    margin-top: 4px;
}
.vigil-list-header {
    display: grid;
    grid-template-columns: 60px 1fr 220px 32px;
    gap: 10px;
    align-items: center;
    padding: 6px 10px;
    background: #eef1f5;
    border: 1px solid #d0d4db;
    border-radius: 6px 6px 0 0;
    font-size: 0.78rem;
    font-weight: 700;
    color: #555;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}
.vigil-row {
    display: grid;
    grid-template-columns: 60px 1fr 220px 32px;
    gap: 10px;
    align-items: center;
    padding: 8px 10px;
    border: 1px solid #d0d4db;
    border-top: none;
    background: #fff;
}
.vigil-row:last-child {
    border-radius: 0 0 6px 6px;
}
.vigil-picto-cell {
    display: flex;
    align-items: center;
    justify-content: center;
}
.vigil-picto {
    width: 48px;
    height: 48px;
    object-fit: contain;
}
.vigil-picto-placeholder {
    width: 48px;
    height: 48px;
    background: #e4e9f0;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: #9ca3af;
}
.vigil-definition {
    font-size: 0.88rem;
    color: #1e2028;
    line-height: 1.4;
}
.vigil-detail-input {
    width: 100%;
    box-sizing: border-box;
    padding: 6px 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.85rem;
    resize: vertical;
    min-height: 52px;
    max-height: 100px;
    font-family: inherit;
}
.vigil-detail-input:focus {
    outline: none;
    border-color: #3d5a80;
}
.vigil-remove-btn {
    background: none;
    border: none;
    color: #aaa;
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.15s;
}
.vigil-remove-btn:hover { color: #c0392b; }
</style>

<script>
// ── Vigilances ──────────────────────────────────────────────────────────────
var _vigilSelected = [];  // [{id, definition, picto, detail}]
var _vigilPictoBase = '{{ asset("PictoVigilancePNG/") }}';

// Pré-remplissage en mode édition
var _vigilInitial = {{ vigilanceDataJson|default('[]')|raw }};
document.addEventListener('DOMContentLoaded', function() {
    _vigilInitial.forEach(function(v) {
        _vigilSelected.push({ id: v.id, definition: v.definition, picto: v.picto || '', detail: v.detail || '' });
    });
    vigilRender();
});

function vigilAdd() {
    var sel = document.getElementById('vigil-dropdown');
    var id = parseInt(sel.value);
    if (!id) return;
    if (_vigilSelected.length >= 5) { alert('Maximum 5 vigilances par intervention.'); return; }
    if (_vigilSelected.some(function(v) { return v.id === id; })) return;
    var opt = sel.options[sel.selectedIndex];
    _vigilSelected.push({
        id: id,
        definition: opt.dataset.definition,
        picto: opt.dataset.picto || '',
        detail: '',
    });
    sel.value = '';
    vigilRender();
}

function vigilRemove(id) {
    _vigilSelected = _vigilSelected.filter(function(v) { return v.id !== id; });
    vigilRender();
}

function vigilRender() {
    var rows = document.getElementById('vigil-rows');
    var list = document.getElementById('vigil-list');
    var counter = document.getElementById('vigil-counter');
    var countEl = document.getElementById('vigil-count');
    rows.innerHTML = '';

    if (_vigilSelected.length === 0) {
        list.style.display = 'none';
        counter.style.display = 'none';
        vigilSerialize();
        return;
    }

    list.style.display = '';
    counter.style.display = '';
    countEl.textContent = _vigilSelected.length;

    _vigilSelected.forEach(function(v) {
        var row = document.createElement('div');
        row.className = 'vigil-row';

        // Picto — utilise picto si renseigné, sinon {id}.png
        var pictoCell = document.createElement('div');
        pictoCell.className = 'vigil-picto-cell';
        var img = document.createElement('img');
        img.src = _vigilPictoBase + (v.picto || v.id + '.png');
        img.className = 'vigil-picto';
        img.onerror = function() { pictoCell.innerHTML = '<div class="vigil-picto-placeholder">⚠</div>'; };
        pictoCell.appendChild(img);
        row.appendChild(pictoCell);

        // Définition
        var def = document.createElement('div');
        def.className = 'vigil-definition';
        def.textContent = v.definition;
        row.appendChild(def);

        // Détail
        var textarea = document.createElement('textarea');
        textarea.className = 'vigil-detail-input';
        textarea.placeholder = 'Informations complémentaires…';
        textarea.value = v.detail;
        textarea.addEventListener('input', function() {
            v.detail = textarea.value;
            vigilSerialize();
        });
        row.appendChild(textarea);

        // Supprimer
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'vigil-remove-btn';
        btn.title = 'Retirer';
        btn.textContent = '✕';
        btn.addEventListener('click', function() { vigilRemove(v.id); });
        row.appendChild(btn);

        rows.appendChild(row);
    });

    vigilSerialize();
}

function vigilSerialize() {
    var hidden = document.getElementById('vigil-hidden');
    if (hidden) hidden.value = JSON.stringify(_vigilSelected.map(function(v) {
        return { id: v.id, detail: v.detail };
    }));
}

function esTileToggle(tile) {
    var isNow = !tile.classList.contains('selected');
    tile.classList.toggle('selected', isNow);
    var select = document.getElementById('tile-select-elementSecurites');
    if (!select) return;
    var val = tile.getAttribute('data-tile-value');
    Array.from(select.options).forEach(function(opt) {
        if (opt.value === val) opt.selected = isNow;
    });
}
document.addEventListener('DOMContentLoaded', function() {
    var autoTiles = document.querySelectorAll('[data-auto-select="true"]');
    var select = document.getElementById('tile-select-elementSecurites');
    if (!select) return;
    autoTiles.forEach(function(tile) {
        var val = tile.getAttribute('data-tile-value');
        Array.from(select.options).forEach(function(opt) {
            if (opt.value === val) opt.selected = true;
        });
    });
});

// ── Teinte champs vides ────────────────────────────────────────────────────
function checkFieldEmpty(el) {
    if (!el || el.type === 'hidden') return;
    el.classList.toggle('field-empty', el.value === '');
}

function initFieldChecks() {
    var fields = document.querySelectorAll('select, input[type="time"], input[type="number"]');
    fields.forEach(function(el) {
        if (!el._emptyListenerAdded) {
            el.addEventListener('change', function() { checkFieldEmpty(el); });
            el.addEventListener('input',  function() { checkFieldEmpty(el); });
            el._emptyListenerAdded = true;
        }
        checkFieldEmpty(el);
    });
}

// Lancement initial + après Stimulus (qui modifie le DOM)
document.addEventListener('DOMContentLoaded', function() {
    initFieldChecks();
    // MutationObserver : re-vérifie dès que Stimulus peuple/réinitialise un select
    var observer = new MutationObserver(function() {
        initFieldChecks();
    });
    var form = document.querySelector('form');
    if (form) {
        observer.observe(form, { childList: true, subtree: true, attributes: true, attributeFilter: ['disabled', 'value'] });
    }
});
</script>
